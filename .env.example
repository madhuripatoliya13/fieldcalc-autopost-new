# Copy to .env and fill in. NEVER commit the real .env.

# --- App ---
APP_NAME=FieldCalc
TIMEZONE=Asia/Kolkata
POST_TIME_LOCAL=09:00

# --- Database (C1) — Neon connection string. Use postgresql+psycopg://...
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/DBNAME?sslmode=require

# --- Caption LLM (C4) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_DAILY_CAP=10
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Instagram / Meta ---
IG_USER_ID=
IG_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=

# --- Image hosting ---
PUBLIC_ASSET_BASE_URL=
CLOUDINARY_URL=

# --- Notifications & ops ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_EMAIL=
SMTP_PASSWORD=
NOTIFICATION_EMAIL=
HEALTHCHECK_PING_URL=
SENTRY_DSN=

# --- Security ---
DASHBOARD_PASSWORD=change-me
RUN_TOKEN=generate-a-long-random-string

# --- Behavior ---
DRY_RUN=true
